# LearnWorlds Assessment Responses Exporter — configuration
# Copy this file to ".env" and fill in the values for your selected mode.
# Do NOT commit or share the real .env file. It may contain sensitive credentials.

# Mode selection: "offline" (read local JSON) or "live" (call LearnWorlds API).
EXPORT_MODE=offline

# LearnWorlds API URL shown in: Settings -> Developers -> API.
# Store WITHOUT a trailing slash (the script strips it anyway).
LEARNWORLDS_API_URL=https://online.executiveducation.novasbe.pt/admin/api

# School / client id, sent as the "Lw-Client" header. Required in live mode.
LEARNWORLDS_SCHOOL_ID=

# A VALID existing LearnWorlds Access Token. Required in live mode.
# This tool never creates or refreshes tokens — paste a working one here manually.
LEARNWORLDS_ACCESS_TOKEN=

# The assessment whose responses you want to export. Required in live mode.
# Also used by the new extractor (python -m extractor.run_extract).
ASSESSMENT_ID=

# Reserved for the extractor's V2 course-discovery (not used yet).
# A course slug (e.g. "my-course-name"), used to discover assessment units.
COURSE_ID=

# Path to the local JSON sample used in offline mode (relative to this folder).
INPUT_JSON_PATH=input/sample_response.json

# Optional: print full Python tracebacks for debugging (true/false).
DEBUG=false

# Optional / reference only — NOT used in v1.
# Kept here only to document that LearnWorlds exposes client credentials.
# The exporter does NOT use a client-credentials flow.
LEARNWORLDS_CLIENT_ID=
LEARNWORLDS_CLIENT_SECRET=
